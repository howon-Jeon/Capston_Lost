<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/blueHeaderLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E5CB3">

        <TextView
            android:id="@+id/textViewBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:text="<"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"
            android:text="내가 쓴 글"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@id/textViewTitle"
            android:layout_marginTop="16dp"
            android:background="@android:color/darker_gray" />

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/blueHeaderLayout"
        android:background="#FFFFFF">

        <RelativeLayout
            android:id="@+id/layoutPost1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/divider1"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/textViewPostTitle1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="제목"
                android:textSize="18sp"
                android:paddingLeft="8dp"/>

            <TextView
                android:id="@+id/textViewItemType1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textViewPostTitle1"
                android:text="물품 종류: "
                android:textSize="16sp"
                android:paddingLeft="8dp" />

            <TextView
                android:id="@+id/textViewFoundDate1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textViewItemType1"
                android:text="분실일자: "
                android:textSize="16sp"
                android:paddingLeft="8dp"/>

            <TextView
                android:id="@+id/textViewFoundLocation1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textViewFoundDate1"
                android:text="분실장소: "
                android:textSize="16sp"
                android:paddingLeft="8dp"/>

            <ImageView
                android:id="@+id/imageView1"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:background="@drawable/write_list_picture1" />

        </RelativeLayout>

        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@id/layoutPost1"
            android:layout_marginTop="16dp"
            android:background="@android:color/darker_gray" />

        <RelativeLayout
            android:id="@+id/layoutPost2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/divider2"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/textViewPostTitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="제목"
                android:textSize="18sp"
                android:paddingLeft="8dp"/>

            <TextView
                android:id="@+id/textViewItemType2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textViewPostTitle2"
                android:text="물품 종류: "
                android:textSize="16sp"
                android:paddingLeft="8dp"/>

            <TextView
                android:id="@+id/textViewFoundDate2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textViewItemType2"
                android:text="분실일자: "
                android:textSize="16sp"
                android:paddingLeft="8dp"/>

            <TextView
                android:id="@+id/textViewFoundLocation2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textViewFoundDate2"
                android:text="분실장소: "
                android:textSize="16sp"
                android:paddingLeft="8dp"/>

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:background="@drawable/write_list_picture2" />

        </RelativeLayout>

    </RelativeLayout>
</RelativeLayout>